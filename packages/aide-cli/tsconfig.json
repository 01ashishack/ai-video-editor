{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "build",
    "tsBuildInfoFile": "./build/tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@aide/core": [
        "../core/dist/index.d.ts"
      ],
      "@aide/ai-command-interpreter": [
        "./src/ai-command-interpreter-shim.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ]
}
